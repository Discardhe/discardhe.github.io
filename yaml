title: discardhe
url: https://discardhe.github.io
baseurl: ""
remote_theme: "mmistakes/minimal-mistakes@4.24.0"
minimal_mistakes_skin: aqua
plugins:
  - jekyll-include-cache
paginate: 5
markdown: kramdown
kramdown:
  input: GFM
include:
  - _pages
collections:
  pages:
    output: true
defaults:
  - scope:
      path: ""
      type: pages
    values:
      layout: single
      author_profile: false
